---
interface Props {
  currentPage?: string;
}

const { currentPage } = Astro.props;

const navItems = [
  { label: "Home", href: "/" },
  { label: "About", href: "/about" },
  { label: "Contact", href: "/contact" },
];
---

<nav class="navigation">
  <ul class="nav-list">
    {navItems.map((item) => (
      <li class="nav-item">
        <a
          href={item.href}
          class={`nav-link ${currentPage === item.href ? "active" : ""}`}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .navigation {
    background-color: var(--nav-bg, #f5f5f5);
    padding: 1rem;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: 2rem;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    text-decoration: none;
    color: var(--nav-text, #333);
    font-weight: 500;
    transition: color 0.3s ease;
  }

  .nav-link:hover {
    color: var(--nav-hover, #0066cc);
  }

  .nav-link.active {
    color: var(--nav-active, #0066cc);
    border-bottom: 2px solid var(--nav-active, #0066cc);
  }
</style>
